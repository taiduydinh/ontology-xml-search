	<owl:NamedIndividual rdf:about="http://example.org/cs_ontology#ComputerScience">
    <rdf:type rdf:resource="http://example.org/cs_ontology#Domain"/><hasWeight>0.1334</hasWeight>
    
	 <encompasses rdf:resource="http://example.org/cs_ontology#DatabaseSystems"/>
    <encompasses rdf:resource="http://example.org/cs_ontology#ArtificialIntelligence"/>
    <encompasses rdf:resource="http://example.org/cs_ontology#OperatingSystems"/>
