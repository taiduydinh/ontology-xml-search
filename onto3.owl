<?xml version="1.0" encoding="ISO-8859-1"?>
<rdf:RDF
    xmlns:rss="http://purl.org/rss/1.0/"
    xmlns:daml="http://www.daml.org/2001/03/daml+oil#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:vcard="http://www.w3.org/2001/vcard-rdf/3.0#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:jms="http://jena.hpl.hp.com/2003/08/jms#"
    xmlns="http://localhost:8080/unnamed.owl#"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:dc="http://purl.org/dc/elements/1.1/"
  xml:base="http://localhost:8080/unnamed.owl#">
  <owl:Ontology rdf:about=""/>
  <owl:Class rdf:ID="document-pendere"/>
  <owl:Class rdf:ID="element_de_connaissance">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="concept_generique"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="presentateur">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#facilitateur"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="cours">
    <rdfs:subClassOf>
      <owl:Class rdf:ID="ressources-pedagogiques"/>
    </rdfs:subClassOf>
    <owl:sameAs>
      <owl:Class rdf:about="#scenario"/>
    </owl:sameAs>
  </owl:Class>
  <owl:Class rdf:ID="Page-web">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#documentation-complementaire"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="acteurs"/>
  <owl:Class rdf:ID="gestionnaire">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#facilitateur"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="information-sur-lien"/>
  <owl:Class rdf:ID="didacticiel">
    <rdfs:subClassOf rdf:resource="#concept_generique"/>
  </owl:Class>
  <owl:Class rdf:ID="Article-scientifique">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#Article"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="facilitateur">
    <rdfs:subClassOf rdf:resource="#acteurs"/>
  </owl:Class>
  <owl:Class rdf:ID="concept">
    <rdfs:subClassOf rdf:resource="#concept_generique"/>
    <rdfs:subClassOf>
      <owl:Restriction>
        <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#int"
        >1</owl:minCardinality>
        <owl:onProperty>
          <owl:ObjectProperty rdf:about="#forme-de"/>
        </owl:onProperty>
      </owl:Restriction>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Article">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#documentation-complementaire"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Guide">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#Livre"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="formateur">
    <rdfs:subClassOf rdf:resource="#facilitateur"/>
  </owl:Class>
  <owl:Class rdf:ID="Note">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#documentation-complementaire"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Manuel">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#Livre"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Journal">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#documentation-complementaire"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="concepteur">
    <rdfs:subClassOf rdf:resource="#facilitateur"/>
  </owl:Class>
  <owl:Class rdf:ID="Livre">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#documentation-complementaire"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="Proceeding">
    <rdfs:subClassOf>
      <owl:Class rdf:about="#documentation-complementaire"/>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:ID="documentation-complementaire">
    <rdfs:subClassOf rdf:resource="#ressources-pedagogiques"/>
  </owl:Class>
  <owl:Class rdf:ID="apprenant">
    <rdfs:subClassOf rdf:resource="#acteurs"/>
  </owl:Class>
  <owl:Class rdf:ID="scenario">
    <rdfs:subClassOf rdf:resource="#concept_generique"/>
    <owl:sameAs rdf:resource="#cours"/>
  </owl:Class>
  <owl:ObjectProperty rdf:ID="enseigne1">
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="#appartient-a-scenario"/>
    </owl:inverseOf>
    <rdfs:range rdf:resource="#element_de_connaissance"/>
    <rdfs:domain rdf:resource="#scenario"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="sous-type">
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
    <rdfs:range rdf:resource="#information-sur-lien"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="implication">
    <rdfs:range rdf:resource="#information-sur-lien"/>
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="collection-doc">
    <rdfs:range rdf:resource="#document-pendere"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string"
    >pour un concept un ou plusieurs document sont attachees
</rdfs:comment>
    <rdfs:domain rdf:resource="#concept_generique"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="constitue-de">
    <rdfs:domain rdf:resource="#didacticiel"/>
    <rdfs:range rdf:resource="#scenario"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="appartient-a-concept">
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="#forme-de"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="#element_de_connaissance"/>
    <rdfs:range rdf:resource="#concept"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="reference">
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
    <rdfs:range rdf:resource="#information-sur-lien"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="cause-resultat">
    <rdfs:range rdf:resource="#information-sur-lien"/>
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="instance">
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
    <rdfs:range rdf:resource="#information-sur-lien"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="contribue-a-enseigner">
    <rdfs:range rdf:resource="#concept"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="#est-enseigne-par"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="#scenario"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="precede-par">
    <rdfs:domain rdf:resource="#concept"/>
    <rdfs:range rdf:resource="#concept"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="#precede"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="doc">
    <rdfs:range rdf:resource="#documentation-complementaire"/>
    <rdfs:domain rdf:resource="#document-pendere"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="enseigne">
    <rdfs:range rdf:resource="#concept"/>
    <rdfs:domain rdf:resource="#didacticiel"/>
    <owl:inverseOf>
      <owl:ObjectProperty rdf:about="#est-enseigne-par-didacticiel"/>
    </owl:inverseOf>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="lien-semantique"/>
  <owl:ObjectProperty rdf:ID="sequentiel">
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
    <rdfs:range rdf:resource="#information-sur-lien"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="forme-de">
    <rdfs:range rdf:resource="#element_de_connaissance"/>
    <rdfs:domain rdf:resource="#concept"/>
    <owl:inverseOf rdf:resource="#appartient-a-concept"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="similaire">
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
    <rdfs:range rdf:resource="#information-sur-lien"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="est-enseigne-par-didacticiel">
    <owl:inverseOf rdf:resource="#enseigne"/>
    <rdfs:domain rdf:resource="#concept"/>
    <rdfs:range rdf:resource="#didacticiel"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="precede">
    <rdfs:range rdf:resource="#concept"/>
    <rdfs:domain rdf:resource="#concept"/>
    <owl:inverseOf rdf:resource="#precede-par"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="appartient-a-scenario">
    <rdfs:range rdf:resource="#scenario"/>
    <rdfs:domain rdf:resource="#element_de_connaissance"/>
    <owl:inverseOf rdf:resource="#enseigne1"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="document-final">
    <rdfs:range rdf:resource="#documentation-complementaire"/>
    <rdfs:domain rdf:resource="#information-sur-lien"/>
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:ID="est-enseigne-par">
    <rdfs:domain rdf:resource="#concept"/>
    <owl:inverseOf rdf:resource="#contribue-a-enseigner"/>
    <rdfs:range rdf:resource="#scenario"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:ID="titre">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="adresse">
    <rdfs:domain rdf:resource="#scenario"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="auteurs">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Article"/>
          <owl:Class rdf:about="#Journal"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="date">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain>
      <owl:Class>
        <owl:unionOf rdf:parseType="Collection">
          <owl:Class rdf:about="#Article"/>
          <owl:Class rdf:about="#Journal"/>
          <owl:Class rdf:about="#Proceeding"/>
          <owl:Class rdf:about="#Livre"/>
        </owl:unionOf>
      </owl:Class>
    </rdfs:domain>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="profil">
    <rdfs:domain rdf:resource="#apprenant"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="adresse-doc">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="poid-concept">
    <rdfs:domain rdf:resource="#document-pendere"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="isbn">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdfs:domain rdf:resource="#Livre"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="degree-certitude">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <rdfs:domain rdf:resource="#information-sur-lien"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="format">
    <rdfs:domain rdf:resource="#Article"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:ID="num">
    <rdfs:domain rdf:resource="#documentation-complementaire"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
  </owl:DatatypeProperty>
  <owl:TransitiveProperty rdf:ID="precede-par2">
    <rdfs:range rdf:resource="#scenario"/>
    <owl:inverseOf>
      <owl:TransitiveProperty rdf:about="#precede2"/>
    </owl:inverseOf>
    <rdfs:domain rdf:resource="#scenario"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:TransitiveProperty>
  <owl:TransitiveProperty rdf:ID="precede-par1">
    <owl:inverseOf>
      <owl:TransitiveProperty rdf:about="#precede1"/>
    </owl:inverseOf>
    <rdfs:range rdf:resource="#element_de_connaissance"/>
    <rdfs:domain rdf:resource="#element_de_connaissance"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:TransitiveProperty>
  <owl:TransitiveProperty rdf:ID="precede2">
    <rdfs:range rdf:resource="#scenario"/>
    <rdfs:domain rdf:resource="#scenario"/>
    <owl:inverseOf rdf:resource="#precede-par2"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:TransitiveProperty>
  <owl:TransitiveProperty rdf:ID="precede1">
    <rdfs:domain rdf:resource="#element_de_connaissance"/>
    <rdfs:range rdf:resource="#element_de_connaissance"/>
    <owl:inverseOf rdf:resource="#precede-par1"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </owl:TransitiveProperty>
  <element_de_connaissance rdf:ID="Agrégation">
    <precede-par1>
      <element_de_connaissance rdf:ID="Classe">
        <appartient-a-concept>
          <concept rdf:ID="UML">
            <est-enseigne-par>
              <scenario rdf:ID="Niveau_conceptuel">
                <enseigne1 rdf:resource="#Classe"/>
                <enseigne1>
                  <element_de_connaissance rdf:ID="Methodes_de_classe">
                    <appartient-a-scenario rdf:resource="#Niveau_conceptuel"/>
                    <appartient-a-concept rdf:resource="#UML"/>
                  </element_de_connaissance>
                </enseigne1>
                <enseigne1>
                  <element_de_connaissance rdf:ID="Arttributs_de_classe">
                    <appartient-a-concept rdf:resource="#UML"/>
                    <appartient-a-scenario rdf:resource="#Niveau_conceptuel"/>
                  </element_de_connaissance>
                </enseigne1>
                <enseigne1>
                  <element_de_connaissance rdf:ID="Diagrammes_de_classes">
                    <appartient-a-concept rdf:resource="#UML"/>
                    <appartient-a-scenario rdf:resource="#Niveau_conceptuel"/>
                  </element_de_connaissance>
                </enseigne1>
                <precede2>
                  <scenario rdf:ID="Niveau_interne">
                    <precede2>
                      <scenario rdf:ID="Sgbd_relationnel">
                        <precede2>
                          <scenario rdf:ID="Sgbd_objet">
                            <precede-par2 rdf:resource="#Sgbd_relationnel"/>
                          </scenario>
                        </precede2>
                        <precede2>
                          <scenario rdf:ID="SQL">
                            <enseigne1>
                              <element_de_connaissance rdf:ID="L_ordre_DROP_VIEW">
                                <appartient-a-concept>
                                  <concept rdf:ID="Langage_de_description_de_données">
                                    <forme-de>
                                      <element_de_connaissance rdf:ID="L_ordre_CREATE_VIEW">
                                        <appartient-a-concept rdf:resource="#Langage_de_description_de_données"/>
                                        <appartient-a-scenario rdf:resource="#SQL"/>
                                      </element_de_connaissance>
                                    </forme-de>
                                    <forme-de>
                                      <element_de_connaissance rdf:ID="L_ordre_DROP_INDEX">
                                        <appartient-a-concept rdf:resource="#Langage_de_description_de_données"/>
                                        <appartient-a-scenario rdf:resource="#SQL"/>
                                      </element_de_connaissance>
                                    </forme-de>
                                    <forme-de rdf:resource="#L_ordre_DROP_VIEW"/>
                                    <est-enseigne-par rdf:resource="#SQL"/>
                                    <forme-de>
                                      <element_de_connaissance rdf:ID="L_ordre_CREATE_INDEX">
                                        <appartient-a-scenario rdf:resource="#SQL"/>
                                        <appartient-a-concept rdf:resource="#Langage_de_description_de_données"/>
                                      </element_de_connaissance>
                                    </forme-de>
                                    <forme-de>
                                      <element_de_connaissance rdf:ID="L_ordre_DROP_TABLE">
                                        <appartient-a-concept rdf:resource="#Langage_de_description_de_données"/>
                                        <appartient-a-scenario rdf:resource="#SQL"/>
                                      </element_de_connaissance>
                                    </forme-de>
                                    <forme-de>
                                      <element_de_connaissance rdf:ID="L_ordre_CREATE_TABLE">
                                        <appartient-a-concept rdf:resource="#Langage_de_description_de_données"/>
                                        <appartient-a-scenario rdf:resource="#SQL"/>
                                      </element_de_connaissance>
                                    </forme-de>
                                    <forme-de>
                                      <element_de_connaissance rdf:ID="Les_types_de_données">
                                        <appartient-a-concept rdf:resource="#Langage_de_description_de_données"/>
                                        <appartient-a-scenario rdf:resource="#SQL"/>
                                      </element_de_connaissance>
                                    </forme-de>
                                    <precede>
                                      <concept rdf:ID="Langage_de_manipulation_de_données">
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="L_odre_UPDATE">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_clause_GROUP_BY">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="L_ordre_INSERT">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_jointure_RIGHT_OUTER_OIN">
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="L_ordre_DELETE">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_jointure_LEFT_OUTER_JOIN">
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_fonction_MIN">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <precede>
                                          <concept rdf:ID="Langage_de_controle_de_données">
                                            <forme-de>
                                              <element_de_connaissance rdf:ID="L_ordre_REVOKE">
                                                <appartient-a-concept rdf:resource="#Langage_de_controle_de_données"/>
                                                <appartient-a-scenario rdf:resource="#SQL"/>
                                              </element_de_connaissance>
                                            </forme-de>
                                            <forme-de>
                                              <element_de_connaissance rdf:ID="L_ordre_GRANT">
                                                <appartient-a-concept rdf:resource="#Langage_de_controle_de_données"/>
                                                <appartient-a-scenario rdf:resource="#SQL"/>
                                              </element_de_connaissance>
                                            </forme-de>
                                            <precede-par rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <est-enseigne-par rdf:resource="#SQL"/>
                                          </concept>
                                        </precede>
                                        <precede-par rdf:resource="#Langage_de_description_de_données"/>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_fonction_AVG">
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_jointure_INNER_JOIN">
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_fonction_COUNT">
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="L_ordre_SELECT">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_fonction_SUM">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_fonction_MAX">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_clause_ORDRED_BY">
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <forme-de>
                                          <element_de_connaissance rdf:ID="La_clause_FROM">
                                            <appartient-a-scenario rdf:resource="#SQL"/>
                                            <appartient-a-concept rdf:resource="#Langage_de_manipulation_de_données"/>
                                          </element_de_connaissance>
                                        </forme-de>
                                        <est-enseigne-par rdf:resource="#SQL"/>
